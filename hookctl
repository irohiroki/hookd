#!/usr/bin/env python3
"""
hookctl — register webhook routes and cron schedules with hookd.

Usage: hookctl <config.yml>

The YAML file may contain 'routes' and/or 'schedules' keys. It must not
contain 'server' or 'log' keys (those are admin-only settings).

Routes are served under /<username>/<path> on the hookd server.
Schedule names are stored internally as <username>/<name>.

The file is installed as routes.d/<username>.yml and hookd reloads
within 2 seconds via a flag file watched by the server process.
"""

import os
import pwd
import shutil
import sys

import yaml

ROUTES_DIR = '/home/rocky/hookd/routes.d'


def die(msg):
    print(f'error: {msg}', file=sys.stderr)
    sys.exit(1)


def validate_cron_format(expr):
    return isinstance(expr, str) and len(expr.split()) == 5


def validate(cfg):
    if not isinstance(cfg, dict):
        die('config must be a YAML mapping')

    for forbidden in ('server', 'log'):
        if forbidden in cfg:
            die(f'"{forbidden}" key is not allowed in user config files')

    has_routes = 'routes' in cfg
    has_schedules = 'schedules' in cfg

    if not has_routes and not has_schedules:
        die('config must contain "routes" and/or "schedules"')

    if has_routes:
        routes = cfg['routes']
        if not isinstance(routes, list):
            die('"routes" must be a list')
        for i, route in enumerate(routes):
            for field in ('path', 'script'):
                if field not in route:
                    die(f'route[{i}] is missing required field "{field}"')
            if not route['path'].startswith('/'):
                die(f'route[{i}].path must start with "/" (got: {route["path"]})')

    if has_schedules:
        schedules = cfg['schedules']
        if not isinstance(schedules, list):
            die('"schedules" must be a list')
        for i, sched in enumerate(schedules):
            for field in ('name', 'cron', 'script'):
                if field not in sched:
                    die(f'schedule[{i}] is missing required field "{field}"')
            if not validate_cron_format(sched['cron']):
                die(f'schedule[{i}].cron must be a 5-field cron expression '
                    f'(got: {sched["cron"]!r})')


def main():
    if len(sys.argv) != 2:
        print(f'Usage: {sys.argv[0]} <config.yml>', file=sys.stderr)
        sys.exit(1)

    src = sys.argv[1]

    try:
        with open(src) as f:
            cfg = yaml.safe_load(f)
    except FileNotFoundError:
        die(f'file not found: {src}')
    except yaml.YAMLError as e:
        die(f'YAML parse error: {e}')

    validate(cfg)

    username = pwd.getpwuid(os.getuid()).pw_name
    dest = os.path.join(ROUTES_DIR, f'{username}.yml')

    try:
        shutil.copy2(src, dest)
    except OSError as e:
        die(f'failed to install config: {e}')

    reload_flag = os.path.join(ROUTES_DIR, '.reload')
    try:
        os.utime(reload_flag, None)
    except FileNotFoundError:
        old_umask = os.umask(0)
        try:
            fd = os.open(reload_flag, os.O_CREAT | os.O_WRONLY, 0o666)
            os.close(fd)
        finally:
            os.umask(old_umask)
    except OSError as e:
        die(f'failed to trigger reload: {e}')

    route_count = len(cfg.get('routes', []))
    sched_count = len(cfg.get('schedules', []))
    parts = []
    if route_count:
        parts.append(f'{route_count} route(s)')
    if sched_count:
        parts.append(f'{sched_count} schedule(s)')
    print(f'registered {" and ".join(parts)} for {username} — hookd will reload within 2 seconds')


if __name__ == '__main__':
    main()
