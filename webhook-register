#!/usr/bin/env python3
"""
webhook-register — register a user's webhook routes with the running server.

Usage: webhook-register <routes.yml>

The YAML file must contain a top-level 'routes' key and must not contain
'server' or 'log' keys (those are admin-only settings). Each route must have
at minimum a 'path' and a 'script' field.

The file is installed as routes.d/<username>.yml and the server reloads
within 2 seconds via a flag file watched by the server process.
"""

import os
import pwd
import shutil
import sys

import yaml

ROUTES_DIR = '/home/rocky/webhook/routes.d'


def die(msg):
    print(f'error: {msg}', file=sys.stderr)
    sys.exit(1)


def validate(cfg):
    if not isinstance(cfg, dict):
        die('config must be a YAML mapping')

    for forbidden in ('server', 'log'):
        if forbidden in cfg:
            die(f'"{forbidden}" key is not allowed in user route files')

    if 'routes' not in cfg:
        die('"routes" key is required')

    routes = cfg['routes']
    if not isinstance(routes, list):
        die('"routes" must be a list')

    for i, route in enumerate(routes):
        for field in ('path', 'script'):
            if field not in route:
                die(f'route[{i}] is missing required field "{field}"')
        if not route['path'].startswith('/'):
            die(f'route[{i}].path must start with "/" (got: {route["path"]})')


def main():
    if len(sys.argv) != 2:
        print(f'Usage: {sys.argv[0]} <routes.yml>', file=sys.stderr)
        sys.exit(1)

    src = sys.argv[1]

    try:
        with open(src) as f:
            cfg = yaml.safe_load(f)
    except FileNotFoundError:
        die(f'file not found: {src}')
    except yaml.YAMLError as e:
        die(f'YAML parse error: {e}')

    validate(cfg)

    username = pwd.getpwuid(os.getuid()).pw_name
    dest = os.path.join(ROUTES_DIR, f'{username}.yml')

    try:
        shutil.copy2(src, dest)
    except OSError as e:
        die(f'failed to install routes: {e}')

    reload_flag = os.path.join(ROUTES_DIR, '.reload')
    try:
        open(reload_flag, 'w').close()
    except OSError as e:
        die(f'failed to trigger reload: {e}')

    route_count = len(cfg['routes'])
    print(f'registered {route_count} route(s) for {username} — server will reload within 2 seconds')


if __name__ == '__main__':
    main()
